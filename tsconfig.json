{
  "compilerOptions": {
    // Output
    "target": "es2023",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["esnext"],
    "outDir": "./lib",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,

    // Strictness — "strict" enables noImplicitAny, strictNullChecks,
    // strictFunctionTypes, strictBindCallApply, strictPropertyInitialization,
    // noImplicitThis, useUnknownInCatchVariables, alwaysStrict.
    // Everything below is NOT covered by "strict" and must be opted in.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "isolatedDeclarations": true,

    // Module resolution
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Build
    "incremental": true,
    "composite": true
  },
  "include": ["src", "./package.json", "./index.ts", "index.d.ts"],
  "exclude": ["node_modules", "lib", "**/*.test.ts"]
}
