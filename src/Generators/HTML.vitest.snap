.layout{display:flex;min-height:calc(100vh - 5rem)}
.sidebar{width:220px;padding:1.5rem;border-right:1px solid #e0e0e0;background:#fff;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0}
