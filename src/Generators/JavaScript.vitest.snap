  sm: tokens.spacingSm,
};
const spacing = (name) => {
  if (!(name in _spacing)) throw new Error(\`Unknown spacing token: \${name}\`);
  return _spacing[name];
};

module.exports = { tokens: tokens, color: color, spacing: spacing, default: tokens };"
