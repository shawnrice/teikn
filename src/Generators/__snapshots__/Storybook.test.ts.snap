exports[`Storybook generator It generates the full token set 1`] = `
"/**
 * Teikn vtest
 * Generated Mon Jan 01 2024 12:00:00
 *
 * Storybook stories for design tokens
 * This file is generated — do not edit manually
 */
import type { Meta, StoryObj } from '@storybook/react';
import { tokens } from "./tokens";
import { FontSample, Swatch, TokenGrid, TokenList, TokenStory } from 'teikn/storybook';

const fontFamilyKeys = ['body'] as const;
const colorKeys = ['primary', 'secondary'] as const;

const meta = {
  title: "Design Tokens",
  tags: ['autodocs'],
  parameters: { layout: 'padded' },
} satisfies Meta;
export default meta;
type Story = StoryObj<typeof meta>;

export const FontFamily: Story = {
  render: () => (
    <TokenStory>
        <TokenList>
          {fontFamilyKeys.map(key => <FontSample key={key} name={key} value={String(tokens[key])} styleProp="fontFamily" />)}
        </TokenList>
    </TokenStory>
  ),
};

export const Color: Story = {
  render: () => (
    <TokenStory>
        <TokenGrid>
          {colorKeys.map(key => <Swatch key={key} name={key} value={String(tokens[key])} />)}
        </TokenGrid>
    </TokenStory>
  ),
};"
`;
