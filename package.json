{
  "name": "teikn",
  "version": "2.0.0-beta.7",
  "description": "Generate design tokens",
  "keywords": [
    "design",
    "design tokens",
    "design-systems"
  ],
  "homepage": "https://github.com/shawnrice/teikn#readme",
  "bugs": {
    "url": "https://github.com/shawnrice/teikn/issues"
  },
  "license": "MIT",
  "author": "Shawn Patrick Rice <rice@shawnrice.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/shawnrice/teikn.git"
  },
  "bin": {
    "teikn": "./lib/src/cli.js"
  },
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/tsconfig.tsbuildinfo"
  ],
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./color": {
      "types": "./lib/src/TokenTypes/Color/index.d.ts",
      "import": "./lib/src/TokenTypes/Color/index.js"
    },
    "./builders": {
      "import": "./lib/src/builders.js",
      "types": "./lib/src/builders.d.ts"
    },
    "./generators": {
      "import": "./lib/src/Generators/index.js",
      "types": "./lib/src/Generators/index.d.ts"
    },
    "./storybook": {
      "import": "./lib/src/storybook/index.js",
      "types": "./lib/src/storybook/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "generate-example": "bun example/example-usage.ts",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/ && oxfmt --write",
    "prepublishOnly": "tsc",
    "storybook": "storybook dev -p 6006",
    "test": "bun test",
    "test:node": "vitest run",
    "test:update": "bun test --update-snapshots && vitest run --update"
  },
  "devDependencies": {
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
