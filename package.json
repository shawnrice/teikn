{
  "name": "teikn",
  "version": "2.0.0-alpha.1",
  "description": "Generate design tokens",
  "keywords": [
    "design",
    "design tokens",
    "design-systems"
  ],
  "homepage": "https://github.com/shawnrice/teikn#readme",
  "bugs": {
    "url": "https://github.com/shawnrice/teikn/issues"
  },
  "license": "MIT",
  "author": "Shawn Patrick Rice <rice@shawnrice.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/shawnrice/teikn.git"
  },
  "bin": "./lib/src/cli.js",
  "files": [
    "lib"
  ],
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./builders": {
      "import": "./lib/src/builders.js",
      "types": "./lib/src/builders.d.ts"
    },
    "./generators": {
      "import": "./lib/src/Generators/index.js",
      "types": "./lib/src/Generators/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "format": "oxfmt --write 'src/' './*.json'",
    "lint": "oxlint src/",
    "prepublishOnly": "tsc",
    "test": "bun test",
    "test:node": "vitest run",
    "storybook": "storybook dev -p 6006",
    "generate-example": "bun example/example-usage.ts"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@types/bun": "^1.3.9",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.52.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.2.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
